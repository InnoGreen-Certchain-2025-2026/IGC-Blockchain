# Remote Besu JSON-RPC endpoint (replace with your server URL)
BESU_RPC_URL=https://YOUR_SERVER_IP_OR_DOMAIN

# Header required by the RPC proxy
X_HEADER_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Network ID in docker-compose/.env
BESU_CHAIN_ID=1337

# Deployer private key (must have 0x prefix)
DEPLOYER_PRIVATE_KEY=0xREPLACE_WITH_YOUR_PRIVATE_KEY

# Optional gas price in wei (0 for private network with min-gas-price=0)
BESU_GAS_PRICE=0

# Optional: backend resources folder for auto copy after deploy
# Example (Java Spring): E:/certificate-backend/src/main/resources
BACKEND_RESOURCES_DIR=
